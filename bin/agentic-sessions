#!/usr/bin/env python3
"""Agentic session manager with optional tmux sidebar.

Relocatable, stdlib-only core. It reads supported agent session JSONL files
and stores user-facing metadata in a sidecar directory rather than editing
sessions.
"""

from __future__ import annotations

import argparse
import curses
import datetime as dt
import json
import os
import re
import shutil
import subprocess
import sys
import textwrap
import time
from dataclasses import dataclass
from functools import lru_cache
from pathlib import Path
from typing import Iterable, Sequence


UUID_RE = re.compile(
    r"[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}"
)
SUPPORTED_PROVIDERS = ("codex", "claude")


@dataclass
class Config:
    provider: str
    agent_home: Path
    sessions_root: Path
    state_root: Path
    names_file: Path
    trash_root: Path


@dataclass
class Session:
    provider: str
    id: str
    path: Path
    timestamp: str
    modified: float
    cwd: str
    source: str
    model_provider: str
    cli_version: str
    first_prompt: str
    last_prompt: str
    custom_title: str = ""
    native_title: str = ""

    @property
    def title(self) -> str:
        if self.custom_title:
            return self.custom_title
        if self.native_title:
            return self.native_title
        if self.first_prompt:
            return self.first_prompt
        if self.cwd:
            return Path(self.cwd).name or self.cwd
        return self.id


def eprint(*args: object) -> None:
    print(*args, file=sys.stderr)


def expand(path: str | Path) -> Path:
    return Path(path).expanduser().resolve()


def normalize_provider(provider: str) -> str:
    provider = provider.strip().lower()
    if provider not in SUPPORTED_PROVIDERS:
        raise SystemExit(f"unsupported provider: {provider}")
    return provider


def parse_providers(value: str) -> list[str]:
    providers: list[str] = []
    for part in re.split(r"[,\s]+", value.strip().lower()):
        if not part:
            continue
        provider = normalize_provider(part)
        if provider not in providers:
            providers.append(provider)
    if not providers:
        raise SystemExit("at least one provider is required")
    return providers


def selected_providers(args: argparse.Namespace) -> list[str]:
    value = getattr(
        args,
        "provider",
        os.environ.get("AGENTIC_SESSION_PROVIDER", os.environ.get("CODEX_SESSION_PROVIDER", "codex,claude")),
    )
    return parse_providers(value)


def provider_title(provider: str) -> str:
    return "Claude" if provider == "claude" else "Codex"


def providers_title(providers: Sequence[str]) -> str:
    return provider_title(providers[0]) if len(providers) == 1 else "Agentic"


def provider_label(provider: str) -> str:
    return "Cl" if provider == "claude" else "Cx"


def sidebar_provider_label(provider: str, width: int) -> str:
    return provider_title(provider) if width >= 48 else provider_label(provider)


def session_name_key(provider: str, session_id: str) -> str:
    return session_id if provider == "codex" else f"{provider}:{session_id}"


def custom_title_for(names: dict, provider: str, session_id: str) -> str:
    custom = names.get(session_name_key(provider, session_id), {})
    if not custom and provider == "codex":
        custom = names.get(session_id, {})
    return str(custom.get("title", "")) if isinstance(custom, dict) else ""


NATIVE_TITLES_KEY = "__native_titles__"


def native_title_for(names: dict, session_id: str) -> str:
    native_titles = names.get(NATIVE_TITLES_KEY, {})
    if not isinstance(native_titles, dict):
        return ""
    return str(native_titles.get(session_id, ""))


def load_codex_native_titles(agent_home: Path) -> dict[str, str]:
    titles: dict[str, str] = {}
    index_path = agent_home / "session_index.jsonl"
    try:
        with index_path.open(errors="replace") as handle:
            for raw in handle:
                try:
                    record = json.loads(raw)
                except Exception:
                    continue
                session_id = str(record.get("id") or "").lower()
                title = str(record.get("thread_name") or "").strip()
                if session_id and title:
                    titles[session_id] = title
    except OSError:
        pass
    return titles


def load_title_metadata(config: Config) -> dict:
    names = load_json_object(config.names_file)
    native_titles = load_codex_native_titles(config.agent_home) if config.provider == "codex" else {}
    if native_titles:
        names = dict(names)
        names[NATIVE_TITLES_KEY] = native_titles
    return names


def parse_env_value(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == value[-1] and value[0] in {"'", '"'}:
        return value[1:-1]
    return value


def load_env_file(path: Path) -> None:
    try:
        lines = path.read_text().splitlines()
    except OSError:
        return
    for line in lines:
        stripped = line.strip()
        if not stripped or stripped.startswith("#") or "=" not in stripped:
            continue
        key, value = stripped.split("=", 1)
        key = key.strip()
        if not key or not re.fullmatch(r"[A-Za-z_][A-Za-z0-9_]*", key):
            continue
        os.environ.setdefault(key, parse_env_value(value))


def load_local_env() -> None:
    script_root = Path(__file__).resolve().parent.parent
    for path in (
        script_root / ".agentic-session-tools.env",
        script_root / ".codex-session-tools.env",
        Path.home() / ".config" / "agentic-session-tools" / "env",
        Path.home() / ".config" / "codex-session-tools" / "env",
    ):
        load_env_file(path)


def default_agent_home(provider: str = "codex") -> Path:
    provider = normalize_provider(provider)
    if provider == "claude":
        candidates: list[Path] = []
        if os.environ.get("CLAUDE_CONFIG_DIR"):
            candidates.append(expand(os.environ["CLAUDE_CONFIG_DIR"]))
        if os.environ.get("CLAUDE_HOME"):
            candidates.append(expand(os.environ["CLAUDE_HOME"]))
        candidates.append(expand("~/.claude"))
        candidates.append(expand("~/.config/claude"))
        for candidate in candidates:
            if (candidate / "projects").exists():
                return candidate
        return candidates[0]

    candidates: list[Path] = []
    if os.environ.get("CODEX_HOME"):
        codex_home = expand(os.environ["CODEX_HOME"])
        candidates.extend([codex_home, codex_home / "agent"])
    if os.environ.get("QGENIE_CLI_HOME"):
        qgenie_home = expand(os.environ["QGENIE_CLI_HOME"])
        candidates.extend([qgenie_home / "agent", qgenie_home])
    candidates.append(expand("~/.config/qgenie-cli/agent"))
    candidates.append(expand("~/.codex"))
    candidates.append(expand("~/.config/codex"))
    for candidate in candidates:
        if (candidate / "sessions").exists():
            return candidate
    return candidates[0]


def build_config(args: argparse.Namespace, provider: str | None = None) -> Config:
    provider = normalize_provider(provider or selected_providers(args)[0])
    agent_home_arg = getattr(args, "agent_home", None)
    sessions_root_arg = getattr(args, "sessions_root", None)
    state_root_arg = getattr(args, "state_root", None)
    agent_home = expand(agent_home_arg) if agent_home_arg else default_agent_home(provider)
    sessions_root_env = os.environ.get("CLAUDE_SESSIONS_ROOT" if provider == "claude" else "CODEX_SESSIONS_ROOT")
    if sessions_root_arg:
        sessions_root = expand(sessions_root_arg)
    elif sessions_root_env:
        sessions_root = expand(sessions_root_env)
    else:
        sessions_root = agent_home / ("projects" if provider == "claude" else "sessions")
    if state_root_arg:
        state_root = expand(state_root_arg)
    elif provider == "claude" and os.environ.get("CLAUDE_SESSION_TOOLS_HOME"):
        state_root = expand(os.environ["CLAUDE_SESSION_TOOLS_HOME"])
    elif os.environ.get("AGENTIC_SESSION_TOOLS_HOME"):
        state_root = expand(os.environ["AGENTIC_SESSION_TOOLS_HOME"])
    elif os.environ.get("CODEX_SESSION_TOOLS_HOME"):
        state_root = expand(os.environ["CODEX_SESSION_TOOLS_HOME"])
    else:
        state_root = (agent_home.parent if agent_home.name == "agent" else agent_home) / "session-tools"
    return Config(
        provider=provider,
        agent_home=agent_home,
        sessions_root=sessions_root,
        state_root=state_root,
        names_file=state_root / "session-names.json",
        trash_root=state_root / "trash",
    )


def build_configs(args: argparse.Namespace) -> list[Config]:
    return [build_config(args, provider) for provider in selected_providers(args)]


def config_for_provider(configs: Sequence[Config], provider: str) -> Config:
    for config in configs:
        if config.provider == provider:
            return config
    raise SystemExit(f"no config for provider: {provider}")


def load_json_object(path: Path) -> dict:
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
    except Exception:
        return {}
    return data if isinstance(data, dict) else {}


def atomic_write_json(path: Path, data: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")
    tmp.replace(path)


def normalize_ws(text: str, limit: int = 180) -> str:
    clean = " ".join(text.split())
    if len(clean) <= limit:
        return clean
    return clean[: max(0, limit - 1)].rstrip() + "…"


def is_injected_user_context(text: str) -> bool:
    stripped = text.strip()
    if not stripped:
        return True
    injected_prefixes = (
        "# AGENTS.md instructions",
        "# Model Set Context",
        "<system>",
        "<developer>",
        "<environment_context>",
        "<turn_aborted>",
        "<skill>",
        "<user>",
        "<assistant>",
        "<tool>",
    )
    if stripped.startswith(injected_prefixes):
        return True
    if "<environment_context>" in stripped and "</environment_context>" in stripped and len(stripped) > 1000:
        return True
    return False


def extract_text_from_message(payload: dict) -> str:
    content = payload.get("content") or []
    texts: list[str] = []
    if isinstance(content, list):
        for item in content:
            if isinstance(item, dict):
                text = item.get("text") or item.get("input_text")
                if isinstance(text, str):
                    texts.append(text)
            elif isinstance(item, str):
                texts.append(item)
    elif isinstance(content, str):
        texts.append(content)
    return "\n".join(texts).strip()


def parse_codex_session(
    path: Path, names: dict, scan_all_prompts: bool = False, fast_sidebar: bool = False
) -> Session | None:
    meta: dict = {}
    first_prompt = ""
    last_prompt = ""
    fallback_id = ""
    match = UUID_RE.search(path.name)
    if match:
        fallback_id = match.group(0).lower()

    try:
        with path.open(errors="replace") as handle:
            total_bytes = 0
            for line_number, raw in enumerate(handle, start=1):
                total_bytes += len(raw)
                try:
                    record = json.loads(raw)
                except Exception:
                    continue
                payload = record.get("payload") or {}
                if record.get("type") == "session_meta" and isinstance(payload, dict):
                    meta = payload
                    continue
                if record.get("type") != "response_item" or not isinstance(payload, dict):
                    continue
                if payload.get("type") != "message" or payload.get("role") != "user":
                    continue
                text = extract_text_from_message(payload)
                if is_injected_user_context(text):
                    continue
                preview = normalize_ws(text)
                if not first_prompt:
                    first_prompt = preview
                if preview:
                    last_prompt = preview
                if first_prompt and not scan_all_prompts:
                    break
                if fast_sidebar and meta and (line_number >= 200 or total_bytes >= 131072):
                    break
    except OSError:
        return None

    session_id = str(meta.get("id") or fallback_id).lower()
    if not session_id:
        return None

    custom_title = custom_title_for(names, "codex", session_id)
    native_title = native_title_for(names, session_id)
    try:
        modified = path.stat().st_mtime
    except OSError:
        modified = 0
    return Session(
        provider="codex",
        id=session_id,
        path=path,
        timestamp=str(meta.get("timestamp") or ""),
        modified=modified,
        cwd=str(meta.get("cwd") or ""),
        source=str(meta.get("source") or ""),
        model_provider=str(meta.get("model_provider") or ""),
        cli_version=str(meta.get("cli_version") or ""),
        first_prompt=first_prompt,
        last_prompt=last_prompt,
        custom_title=str(custom_title),
        native_title=str(native_title),
    )


def parse_claude_session(
    path: Path, names: dict, scan_all_prompts: bool = False, fast_sidebar: bool = False
) -> Session | None:
    first_prompt = ""
    last_prompt = ""
    session_id = ""
    timestamp = ""
    cwd = ""
    cli_version = ""
    model_provider = ""
    entrypoint = ""
    native_title = ""
    match = UUID_RE.search(path.name)
    if match:
        session_id = match.group(0).lower()

    try:
        with path.open(errors="replace") as handle:
            total_bytes = 0
            for line_number, raw in enumerate(handle, start=1):
                total_bytes += len(raw)
                try:
                    record = json.loads(raw)
                except Exception:
                    continue
                if not session_id and record.get("sessionId"):
                    session_id = str(record.get("sessionId")).lower()
                if not timestamp and record.get("timestamp"):
                    timestamp = str(record.get("timestamp"))
                if not cwd and record.get("cwd"):
                    cwd = str(record.get("cwd"))
                if not cli_version and record.get("version"):
                    cli_version = str(record.get("version"))
                if not entrypoint and record.get("entrypoint"):
                    entrypoint = str(record.get("entrypoint"))
                if not native_title:
                    native_title = str(
                        record.get("name")
                        or record.get("displayName")
                        or record.get("sessionName")
                        or record.get("title")
                        or record.get("slug")
                        or ""
                    ).strip()

                message = record.get("message")
                if isinstance(message, dict) and not model_provider and message.get("model"):
                    model_provider = str(message.get("model"))

                text = ""
                if record.get("type") == "last-prompt" and isinstance(record.get("lastPrompt"), str):
                    text = str(record.get("lastPrompt"))
                elif record.get("type") == "user" and isinstance(message, dict) and message.get("role") == "user":
                    text = extract_text_from_message(message)

                if not text or is_injected_user_context(text):
                    continue
                preview = normalize_ws(text)
                if not first_prompt:
                    first_prompt = preview
                if preview:
                    last_prompt = preview
                if first_prompt and not scan_all_prompts and (native_title or line_number >= 40):
                    break
                if fast_sidebar and session_id and (line_number >= 200 or total_bytes >= 131072):
                    break
    except OSError:
        return None

    if not session_id:
        return None

    custom_title = custom_title_for(names, "claude", session_id)
    if not native_title:
        native_title = native_title_for(names, session_id)
    try:
        modified = path.stat().st_mtime
    except OSError:
        modified = 0
    return Session(
        provider="claude",
        id=session_id,
        path=path,
        timestamp=timestamp,
        modified=modified,
        cwd=cwd,
        source=entrypoint or "claude-code",
        model_provider=model_provider,
        cli_version=cli_version,
        first_prompt=first_prompt,
        last_prompt=last_prompt,
        custom_title=str(custom_title),
        native_title=str(native_title),
    )


def parse_session(
    path: Path, names: dict, provider: str, scan_all_prompts: bool = False, fast_sidebar: bool = False
) -> Session | None:
    if provider == "claude":
        return parse_claude_session(path, names, scan_all_prompts=scan_all_prompts, fast_sidebar=fast_sidebar)
    return parse_codex_session(path, names, scan_all_prompts=scan_all_prompts, fast_sidebar=fast_sidebar)


def codex_session_meta_from_path(path: Path) -> dict:
    try:
        with path.open(errors="replace") as handle:
            for line_number, raw in enumerate(handle, start=1):
                if line_number > 20:
                    break
                try:
                    record = json.loads(raw)
                except Exception:
                    continue
                payload = record.get("payload") or {}
                if record.get("type") == "session_meta" and isinstance(payload, dict):
                    return payload
    except OSError:
        pass
    return {}


def codex_is_root_session_meta(meta: dict) -> bool:
    return meta.get("source") == "cli"


def claude_session_summary_from_path(path: Path) -> dict:
    summary: dict = {}
    try:
        with path.open(errors="replace") as handle:
            for line_number, raw in enumerate(handle, start=1):
                if line_number > 40:
                    break
                try:
                    record = json.loads(raw)
                except Exception:
                    continue
                if not summary.get("session_id") and record.get("sessionId"):
                    summary["session_id"] = str(record.get("sessionId")).lower()
                if not summary.get("timestamp") and record.get("timestamp"):
                    summary["timestamp"] = str(record.get("timestamp"))
                if not summary.get("cwd") and record.get("cwd"):
                    summary["cwd"] = str(record.get("cwd"))
                if not summary.get("cli_version") and record.get("version"):
                    summary["cli_version"] = str(record.get("version"))
                if not summary.get("source") and record.get("entrypoint"):
                    summary["source"] = str(record.get("entrypoint"))
                if not summary.get("native_title"):
                    native_title = str(
                        record.get("name")
                        or record.get("displayName")
                        or record.get("sessionName")
                        or record.get("title")
                        or record.get("slug")
                        or ""
                    ).strip()
                    if native_title:
                        summary["native_title"] = native_title
                if record.get("isSidechain") is True:
                    summary["sidechain"] = True
                message = record.get("message")
                if isinstance(message, dict) and not summary.get("model_provider") and message.get("model"):
                    summary["model_provider"] = str(message.get("model"))
                if (
                    summary.get("source")
                    and summary.get("cwd")
                    and summary.get("timestamp")
                    and summary.get("native_title")
                ):
                    break
    except OSError:
        pass
    return summary


def claude_is_root_session_summary(summary: dict) -> bool:
    if summary.get("sidechain"):
        return False
    source = str(summary.get("source") or "")
    return not source or source == "cli"


def include_session_path(config: Config, path: Path, include_generated: bool = False) -> bool:
    if include_generated:
        return True
    if config.provider == "codex":
        return codex_is_root_session_meta(codex_session_meta_from_path(path))
    if config.provider == "claude":
        return claude_is_root_session_summary(claude_session_summary_from_path(path))
    return True


def load_sessions(
    config: Config,
    query: str = "",
    limit: int = 0,
    scan_all_prompts: bool = False,
    fast_sidebar: bool = False,
    include_generated: bool = False,
) -> list[Session]:
    names = load_title_metadata(config)
    files = session_files(config)
    sessions: list[Session] = []
    seen_ids: set[str] = set()
    for path in files:
        if not include_session_path(config, path, include_generated=include_generated):
            continue
        session = parse_session(
            path, names, config.provider, scan_all_prompts=scan_all_prompts, fast_sidebar=fast_sidebar
        )
        if not session or session.id in seen_ids:
            continue
        seen_ids.add(session.id)
        if query and query.lower() not in session_haystack(session):
            continue
        sessions.append(session)
        if limit and len(sessions) >= limit:
            break
    if query:
        sessions.sort(key=lambda session: session.modified, reverse=True)
    return sessions


def load_sessions_from_configs(
    configs: Sequence[Config],
    query: str = "",
    limit: int = 0,
    scan_all_prompts: bool = False,
    fast_sidebar: bool = False,
    include_generated: bool = False,
) -> list[Session]:
    sessions: list[Session] = []
    for config in configs:
        sessions.extend(
            load_sessions(
                config,
                query,
                limit=limit,
                scan_all_prompts=scan_all_prompts,
                fast_sidebar=fast_sidebar,
                include_generated=include_generated,
            )
        )
    sessions.sort(key=lambda session: session.modified, reverse=True)
    if limit:
        return sessions[:limit]
    return sessions


def session_files(config: Config) -> list[Path]:
    infos = session_file_infos(config)
    infos.sort(key=lambda item: item[0], reverse=True)
    return [path for _, path in infos]


def is_session_file(config: Config, name: str) -> bool:
    if not name.endswith(".jsonl"):
        return False
    return True if config.provider == "claude" else name.startswith("rollout-")


def session_file_infos(config: Config) -> list[tuple[float, Path]]:
    infos: list[tuple[float, Path]] = []
    stack = [config.sessions_root]
    while stack:
        directory = stack.pop()
        try:
            with os.scandir(directory) as entries:
                for entry in entries:
                    try:
                        if entry.is_dir(follow_symlinks=False):
                            stack.append(Path(entry.path))
                        elif entry.is_file(follow_symlinks=False) and is_session_file(config, entry.name):
                            infos.append((entry.stat(follow_symlinks=False).st_mtime, Path(entry.path)))
                    except OSError:
                        continue
        except OSError:
            continue
    return infos


def session_id_from_path(path: Path) -> str:
    match = UUID_RE.search(path.name)
    return match.group(0).lower() if match else ""


def light_session_from_path(config: Config, path: Path, names: dict) -> Session | None:
    session_id = session_id_from_path(path)
    if not session_id:
        return None
    meta: dict = {}
    if config.provider == "codex":
        meta = codex_session_meta_from_path(path)
        session_id = str(meta.get("id") or session_id).lower()
    elif config.provider == "claude":
        meta = claude_session_summary_from_path(path)
        session_id = str(meta.get("session_id") or session_id).lower()
    try:
        modified = path.stat().st_mtime
    except OSError:
        modified = 0
    return Session(
        provider=config.provider,
        id=session_id,
        path=path,
        timestamp=str(meta.get("timestamp") or ""),
        modified=modified,
        cwd=str(meta.get("cwd") or ""),
        source=str(meta.get("source") or ""),
        model_provider=str(meta.get("model_provider") or ""),
        cli_version=str(meta.get("cli_version") or ""),
        first_prompt="",
        last_prompt="",
        custom_title=custom_title_for(names, config.provider, session_id),
        native_title=str(meta.get("native_title") or native_title_for(names, session_id)),
    )


def load_session_index(config: Config, query: str = "", limit: int = 0, include_generated: bool = False) -> list[Session]:
    names = load_title_metadata(config)
    sessions: list[Session] = []
    for path in session_files(config):
        if not include_session_path(config, path, include_generated=include_generated):
            continue
        session = light_session_from_path(config, path, names)
        if not session:
            continue
        if query and query.lower() not in session_haystack(session):
            continue
        sessions.append(session)
        if limit and len(sessions) >= limit:
            break
    return sessions


def load_session_index_from_configs(
    configs: Sequence[Config], query: str = "", limit: int = 0, include_generated: bool = False
) -> list[Session]:
    sessions: list[Session] = []
    for config in configs:
        sessions.extend(load_session_index(config, query, limit=limit, include_generated=include_generated))
    sessions.sort(key=lambda session: session.modified, reverse=True)
    if limit:
        return sessions[:limit]
    return sessions


class SidebarIndexLoader:
    def __init__(self, configs: Sequence[Config], query: str = "", include_generated: bool = False):
        self.query = query.lower()
        self.include_generated = include_generated
        self.names_by_provider = {config.provider: load_title_metadata(config) for config in configs}
        self.pending: list[tuple[float, Config, Path]] = []
        self.index = 0
        self.done = False
        self.scanned = 0
        self.seen: set[str] = set()
        for config in configs:
            for modified, path in session_file_infos(config):
                self.pending.append((modified, config, path))
        self.pending.sort(key=lambda row: row[0], reverse=True)

    def load_more(self, existing_count: int, limit: int = 0, path_budget: int = 200) -> list[Session]:
        if self.done:
            return []
        added: list[Session] = []
        checked = 0
        while self.index < len(self.pending) and checked < path_budget:
            if limit and existing_count + len(added) >= limit:
                self.done = True
                break
            _, config, path = self.pending[self.index]
            self.index += 1
            checked += 1
            self.scanned += 1
            if not include_session_path(config, path, include_generated=self.include_generated):
                continue
            session = light_session_from_path(config, path, self.names_by_provider.get(config.provider, {}))
            if not session:
                continue
            key = session_name_key(session.provider, session.id)
            if key in self.seen:
                continue
            self.seen.add(key)
            if self.query and self.query not in session_haystack(session):
                continue
            added.append(session)
        if self.index >= len(self.pending):
            self.done = True
        return added

    def status(self, count: int) -> str:
        if self.done:
            return f"loaded {count} sessions"
        return f"loaded {count} sessions; scanning {self.scanned}/{len(self.pending)} files"


def looks_like_id_fragment(selector: str) -> bool:
    needle = selector.strip().lower()
    return len(needle) >= 4 and all(char in "0123456789abcdef-" for char in needle)


def resolve_session_selector(
    config: Config, selector: str, match_limit: int = 200, include_generated: bool = False
) -> Session:
    names = load_title_metadata(config)
    needle = selector.strip().lower()
    if looks_like_id_fragment(needle):
        matches = [path for path in session_files(config) if needle in path.name.lower()]
        sessions = []
        for path in matches:
            if not include_session_path(config, path, include_generated=include_generated):
                continue
            session = parse_session(path, names, config.provider)
            if session:
                sessions.append(session)
        if sessions:
            return resolve_session(sessions, selector)
    return resolve_session(load_sessions(config, selector, limit=match_limit, include_generated=include_generated), selector)


def resolve_session_selector_any(
    configs: Sequence[Config], selector: str, match_limit: int = 200, include_generated: bool = False
) -> Session:
    if len(configs) == 1:
        return resolve_session_selector(configs[0], selector, match_limit, include_generated=include_generated)
    sessions: list[Session] = []
    needle = selector.strip().lower()
    for config in configs:
        names = load_title_metadata(config)
        if looks_like_id_fragment(needle):
            for path in session_files(config):
                if needle not in path.name.lower():
                    continue
                if not include_session_path(config, path, include_generated=include_generated):
                    continue
                session = parse_session(path, names, config.provider)
                if session:
                    sessions.append(session)
        else:
            sessions.extend(load_sessions(config, selector, limit=match_limit, include_generated=include_generated))
    sessions.sort(key=lambda session: session.modified, reverse=True)
    return resolve_session(sessions[:match_limit] if match_limit else sessions, selector)


def session_haystack(session: Session) -> str:
    return "\n".join(
        [session.provider, session.id, session.title, session.first_prompt, session.last_prompt, session.cwd, str(session.path)]
    ).lower()


def format_time(epoch: float) -> str:
    if not epoch:
        return "?"
    return dt.datetime.fromtimestamp(epoch).strftime("%Y-%m-%d %H:%M")


@lru_cache(maxsize=1)
def home_path_aliases() -> tuple[tuple[Path, str], ...]:
    home = Path.home()
    aliases: list[tuple[Path, str]] = []
    try:
        aliases.append((home.resolve(), "~"))
    except OSError:
        aliases.append((home, "~"))
    try:
        children = list(home.iterdir())
    except OSError:
        children = []
    for child in children:
        try:
            if child.is_symlink() and child.is_dir():
                aliases.append((child.resolve(), "~/" + child.name))
        except OSError:
            continue
    aliases.sort(key=lambda item: len(str(item[0])), reverse=True)
    return tuple(aliases)


def display_cwd(cwd: str) -> str:
    if not cwd:
        return "-"
    path = Path(cwd).expanduser()
    try:
        resolved = path.resolve()
    except OSError:
        resolved = path
    for root, label in home_path_aliases():
        try:
            relative = resolved.relative_to(root)
        except ValueError:
            continue
        suffix = str(relative)
        return label if not suffix or suffix == "." else label + "/" + suffix
    return str(path)


def short_cwd(cwd: str, width: int = 24) -> str:
    text = display_cwd(cwd)
    try:
        display_width = max(1, width)
    except TypeError:
        display_width = 24
    if len(text) > display_width:
        if text.startswith("~/") and display_width >= 6:
            return "~/…" + text[-(display_width - 3) :]
        return "…" + text[-(display_width - 1) :]
    return text


def shorten(text: str, width: int) -> str:
    text = text.replace("\n", " ")
    if len(text) <= width:
        return text
    return text[: max(0, width - 1)].rstrip() + "…"


def print_sessions(sessions: Sequence[Session], long: bool = False, json_output: bool = False) -> None:
    if json_output:
        rows = []
        for s in sessions:
            rows.append(
                {
                    "provider": s.provider,
                    "id": s.id,
                    "title": s.title,
                    "custom_title": s.custom_title,
                    "native_title": s.native_title,
                    "timestamp": s.timestamp,
                    "modified": s.modified,
                    "modified_text": format_time(s.modified),
                    "cwd": s.cwd,
                    "first_prompt": s.first_prompt,
                    "last_prompt": s.last_prompt,
                    "path": str(s.path),
                    "source": s.source,
                    "model_provider": s.model_provider,
                    "cli_version": s.cli_version,
                }
            )
        print(json.dumps(rows, indent=2))
        return

    width = shutil.get_terminal_size((120, 24)).columns
    if long:
        if not sessions:
            print("no sessions found")
            return
        for s in sessions:
            print(f"{s.provider}:{s.id}  {format_time(s.modified)}  {s.title}")
            print(f"  cwd:  {s.cwd or '-'}")
            print(f"  file: {s.path}")
            if s.first_prompt and s.first_prompt != s.title:
                print(f"  first: {s.first_prompt}")
        return

    title_width = max(20, width - 15 - 18 - 26 - 9)
    print(f"{'PROVIDER':8} {'ID':12} {'MODIFIED':16} {'CWD':24} TITLE")
    print(f"{'-'*8} {'-'*12} {'-'*16} {'-'*24} {'-'*min(title_width, 30)}")
    if not sessions:
        print("no sessions found")
        return
    for s in sessions:
        print(
            f"{s.provider[:8]:8} {s.id[:12]:12} {format_time(s.modified):16} {short_cwd(s.cwd):24} {shorten(s.title, title_width)}"
        )


def resolve_session(sessions: Sequence[Session], selector: str) -> Session:
    needle = selector.lower().strip()
    if not needle:
        raise SystemExit("empty session selector")
    exact = [s for s in sessions if s.id == needle]
    if len(exact) == 1:
        return exact[0]
    prefix = [s for s in sessions if s.id.startswith(needle)]
    if len(prefix) == 1:
        return prefix[0]
    contains = [s for s in sessions if needle in session_haystack(s)]
    if len(contains) == 1:
        return contains[0]
    if not prefix and not contains:
        raise SystemExit(f"no session matches: {selector}")
    matches = prefix or contains
    print_sessions(matches[:10])
    raise SystemExit(f"ambiguous selector {selector!r}; use a longer id/title fragment")


def command_list(args: argparse.Namespace) -> int:
    configs = build_configs(args)
    sessions = load_sessions_from_configs(
        configs,
        args.query or "",
        limit=args.limit,
        scan_all_prompts=args.scan_all_prompts,
        include_generated=args.all,
    )
    print_sessions(sessions, long=args.long, json_output=args.json)
    return 0


def include_generated_sessions(args: argparse.Namespace) -> bool:
    return bool(getattr(args, "all", False))


def command_rename(args: argparse.Namespace) -> int:
    configs = build_configs(args)
    session = resolve_session_selector_any(
        configs, args.selector, args.match_limit, include_generated=include_generated_sessions(args)
    )
    config = config_for_provider(configs, session.provider)
    names = load_json_object(config.names_file)
    key = session_name_key(session.provider, session.id)
    title = args.title.strip()
    if not title:
        names.pop(key, None)
        action = "cleared custom title for"
    else:
        names[key] = {
            "title": title,
            "updated_at": dt.datetime.now(dt.timezone.utc).isoformat(),
            "provider": session.provider,
            "session_path": str(session.path),
        }
        action = "renamed"
    atomic_write_json(config.names_file, names)
    print(f"{action} {session.id[:12]} -> {title or session.title}")
    return 0


def trash_destination(config: Config, session: Session) -> Path:
    try:
        relative = session.path.relative_to(config.sessions_root)
    except ValueError:
        relative = Path(session.path.name)
    stamp = dt.datetime.now().strftime("%Y%m%d-%H%M%S")
    return config.trash_root / stamp / relative


def move_to_trash(config: Config, session: Session) -> Path:
    dest = trash_destination(config, session)
    dest.parent.mkdir(parents=True, exist_ok=True)
    shutil.move(str(session.path), str(dest))
    manifest = config.trash_root / "manifest.jsonl"
    manifest.parent.mkdir(parents=True, exist_ok=True)
    with manifest.open("a") as handle:
        handle.write(
            json.dumps(
                {
                    "provider": session.provider,
                    "id": session.id,
                    "title": session.title,
                    "from": str(session.path),
                    "to": str(dest),
                    "deleted_at": dt.datetime.now(dt.timezone.utc).isoformat(),
                }
            )
            + "\n"
        )
    return dest


def command_delete(args: argparse.Namespace) -> int:
    configs = build_configs(args)
    session = resolve_session_selector_any(
        configs, args.selector, args.match_limit, include_generated=include_generated_sessions(args)
    )
    config = config_for_provider(configs, session.provider)
    if not args.yes:
        answer = input(f"Move session {session.id} ({session.title}) to trash? [y/N] ").strip().lower()
        if answer not in {"y", "yes"}:
            print("not deleted")
            return 1
    dest = move_to_trash(config, session)
    print(f"moved to trash: {dest}")
    return 0


def command_resume(args: argparse.Namespace) -> int:
    configs = build_configs(args)
    session = resolve_session_selector_any(
        configs, args.selector, args.match_limit, include_generated=include_generated_sessions(args)
    )
    agent_bin = agent_bin_for(args, session.provider)
    command = resume_command(session.provider, agent_bin, session.id)
    if args.print_command:
        print(resume_shell_command(session, agent_bin))
        return 0
    if session.cwd:
        os.chdir(session.cwd)
    os.execvp(command[0], command)
    return 127


def command_paths(args: argparse.Namespace) -> int:
    configs = build_configs(args)
    for index, config in enumerate(configs):
        if index:
            print()
        print(f"provider={config.provider}")
        print(f"agent_home={config.agent_home}")
        print(f"sessions_root={config.sessions_root}")
        print(f"state_root={config.state_root}")
        print(f"names_file={config.names_file}")
        print(f"trash_root={config.trash_root}")
    return 0


def command_doctor(args: argparse.Namespace) -> int:
    core_checks = [
        ("python", sys.executable, True),
        ("python-curses", "stdlib curses import", True),
    ]
    core_ok = True
    for name, value, passed in core_checks:
        status = "ok" if passed else "missing"
        print(f"{status:8} required {name:16} {value}")
        core_ok = core_ok and passed

    configs = build_configs(args)
    for config in configs:
        passed = config.sessions_root.exists()
        status = "ok" if passed else "missing"
        print(f"{status:8} required {config.provider + '_sessions':16} {config.sessions_root}")
        core_ok = core_ok and passed

    optional_checks = []
    for config in configs:
        agent_bin = agent_bin_for(args, config.provider)
        agent_bin_ok = command_is_available(agent_bin) or bool(
            os.environ.get("CLAUDE_BIN" if config.provider == "claude" else "CODEX_BIN")
        )
        optional_checks.append(
            (
                config.provider,
                agent_bin,
                agent_bin_ok,
                f"required for resume/tmux Enter; {('CLAUDE_BIN' if config.provider == 'claude' else 'CODEX_BIN')} is trusted if set",
            )
        )
    optional_checks.append(
        ("tmux", shutil.which("tmux") or "tmux", shutil.which("tmux") is not None, "required for tmux sidebar")
    )
    optional_ok = True
    for name, value, passed, note in optional_checks:
        status = "ok" if passed else "missing"
        print(f"{status:8} optional {name:16} {value} ({note})")
        optional_ok = optional_ok and passed
    if args.strict and not optional_ok:
        return 1
    return 0 if core_ok else 1


def ensure_tmux() -> str:
    tmux = shutil.which("tmux")
    if not tmux:
        raise SystemExit("tmux is required for sidebar mode")
    return tmux


def shell_quote(value: str) -> str:
    return "'" + value.replace("'", "'\\''") + "'"


def command_is_available(command: str) -> bool:
    path = Path(command).expanduser()
    if path.parent != Path(".") or command.startswith("~"):
        return path.exists() and os.access(path, os.X_OK)
    return shutil.which(command) is not None


def default_codex_bin() -> str:
    env_bin = os.environ.get("CODEX_BIN")
    if env_bin:
        candidate = Path(env_bin).expanduser()
        if candidate.parent != Path(".") or env_bin.startswith("~"):
            return str(candidate)
        return env_bin
    path_bin = shutil.which("codex")
    if path_bin:
        return path_bin
    candidates = [
        Path.home() / ".local" / "bin" / "codex",
        Path("/usr/local/bin/codex"),
        Path("/opt/codex/bin/codex"),
    ]
    for candidate in candidates:
        if candidate.exists() and os.access(candidate, os.X_OK):
            return str(candidate)
    return "codex"


def default_claude_bin() -> str:
    env_bin = os.environ.get("CLAUDE_BIN")
    if env_bin:
        candidate = Path(env_bin).expanduser()
        if candidate.parent != Path(".") or env_bin.startswith("~"):
            return str(candidate)
        return env_bin
    path_bin = shutil.which("claude")
    if path_bin:
        return path_bin
    candidates = [
        Path.home() / ".local" / "bin" / "claude",
        Path("/usr/local/bin/claude"),
        Path("/opt/claude/bin/claude"),
    ]
    for candidate in candidates:
        if candidate.exists() and os.access(candidate, os.X_OK):
            return str(candidate)
    return "claude"


def agent_bin_for(args: argparse.Namespace, provider: str) -> str:
    if provider == "claude":
        return getattr(args, "claude_bin", default_claude_bin())
    return getattr(args, "codex_bin", default_codex_bin())


def resume_command(provider: str, agent_bin: str, session_id: str) -> list[str]:
    if provider == "claude":
        return [agent_bin, "--resume", session_id]
    return [agent_bin, "resume", session_id]


def resume_shell_command(session: Session, agent_bin: str) -> str:
    command = " ".join(shell_quote(part) for part in resume_command(session.provider, agent_bin, session.id))
    if session.cwd:
        return "cd " + shell_quote(session.cwd) + " && " + command
    return command


def run_tmux(args: Sequence[str], dry_run: bool = False) -> subprocess.CompletedProcess[str] | None:
    command = ["tmux", *args]
    if dry_run:
        print("+ " + " ".join(shell_quote(part) if " " in part else part for part in command))
        return None
    return subprocess.run(command, text=True, check=True, capture_output=True)


def split_sidebar_pane(target_pane: str, width: str, sidebar_cmd: str, dry_run: bool = False) -> str:
    args = ["split-window", "-h", "-b", "-l", width, "-t", target_pane, "-P", "-F", "#{pane_id}", sidebar_cmd]
    result = run_tmux(args, dry_run)
    return result.stdout.strip() if result and result.stdout else ""


def set_window_option(target_pane: str, name: str, value: str, dry_run: bool = False) -> None:
    run_tmux(["set-option", "-wq", "-t", target_pane, name, value], dry_run)


def remember_sidebar_reopen(target_pane: str, sidebar_pane: str, sidebar_cmd: str, width: str, dry_run: bool = False) -> None:
    set_window_option(target_pane, "@agentic_sessions_target_pane", target_pane, dry_run)
    set_window_option(target_pane, "@agentic_sessions_sidebar_pane", sidebar_pane, dry_run)
    set_window_option(target_pane, "@agentic_sessions_sidebar_width", width, dry_run)
    set_window_option(target_pane, "@agentic_sessions_sidebar_cmd", sidebar_cmd, dry_run)


def tmux_status_title(providers: Sequence[str]) -> str:
    title = providers_title(providers)
    return f"#[fg=colour235,bg=colour180,bold] {title} Sessions #[default]"


def tmux_status_hint(providers: Sequence[str]) -> str:
    prefix = tmux_prefix_key("prefix")
    return (
        f"#[fg=colour180]{prefix}+? keys "
        f"#[fg=colour244]{prefix}+b sidebar "
        f"#[fg=colour244]{prefix}+←/→ panes "
        f"#[fg=colour244]mouse focus"
    )


def tmux_help_lines(providers: Sequence[str], prefix: str | None = None) -> list[str]:
    prefix = prefix or tmux_prefix_key("prefix")
    return [
        f"{providers_title(providers)} Sessions keys",
        "",
        "Sidebar",
        "  ↑/↓ or j/k     move selection",
        "  Enter          resume selected session in the right pane",
        "  r              native rename the active resumed session",
        "  d              trash selected session after DELETE",
        "  /, c, R        search, clear search, refresh",
        "  ?              expand/collapse sidebar help",
        "  q              close sidebar pane",
        "",
        "Tmux",
        f"  {prefix} + ?        show this help popup from either pane",
        f"  {prefix} + b        reopen or focus the sidebar",
        f"  {prefix} + Left     focus sidebar pane",
        f"  {prefix} + Right    focus agent pane",
        "  mouse click     focus clicked pane when tmux mouse is on",
    ]


def tmux_help_popup_command(providers: Sequence[str]) -> tuple[str, str]:
    title = f"{providers_title(providers)} Sessions keys"
    body = "\n".join(tmux_help_lines(providers)) + "\n\nPress Enter to close."
    command = "printf %s " + shell_quote(body) + "; IFS= read -r _"
    return title, command


def tmux_help_fallback_message(providers: Sequence[str]) -> str:
    prefix = tmux_prefix_key("prefix")
    return f"{providers_title(providers)}: Enter resume | / search | ? sidebar help | {prefix}+b sidebar | {prefix}+←/→ panes"


def tmux_help_popup_script(providers: Sequence[str]) -> str:
    title, command = tmux_help_popup_command(providers)
    fallback = tmux_help_fallback_message(providers)
    return (
        "if tmux display-popup -E -w 78% -h 70% -T "
        + shell_quote(title)
        + " "
        + shell_quote(command)
        + "; then :; else tmux display-message "
        + shell_quote(fallback)
        + "; fi"
    )


def show_tmux_help_popup(providers: Sequence[str]) -> bool:
    title, command = tmux_help_popup_command(providers)
    result = subprocess.run(
        ["tmux", "display-popup", "-E", "-w", "78%", "-h", "70%", "-T", title, command],
        text=True,
        check=False,
        capture_output=True,
    )
    if result.returncode == 0:
        return True
    subprocess.run(["tmux", "display-message", tmux_help_fallback_message(providers)], check=False)
    return False


def ensure_tmux_status_segment(
    option_name: str,
    marker: str,
    original_marker: str,
    segment: str,
    append: bool,
    dry_run: bool = False,
) -> None:
    current = ""
    if not dry_run:
        try:
            result = subprocess.run(
                ["tmux", "show-option", "-qv", option_name],
                text=True,
                check=False,
                capture_output=True,
            )
            current = result.stdout.rstrip("\n") if result.returncode == 0 else ""
        except Exception:
            current = ""
    if marker not in current:
        run_tmux(["set-option", "-q", original_marker, current], dry_run)
        separator = " " if current else ""
        updated = current + separator + segment if append else segment + separator + current
        run_tmux(["set-option", "-q", option_name, updated], dry_run)


def ensure_tmux_status_length(option_name: str, minimum: int, dry_run: bool = False) -> None:
    current = 0
    if not dry_run:
        try:
            result = subprocess.run(
                ["tmux", "show-option", "-qv", option_name],
                text=True,
                check=False,
                capture_output=True,
            )
            current = int(result.stdout.strip()) if result.returncode == 0 and result.stdout.strip() else 0
        except Exception:
            current = 0
    if current < minimum:
        run_tmux(["set-option", "-q", option_name, str(minimum)], dry_run)


def install_tmux_status_hint(providers: Sequence[str], dry_run: bool = False) -> None:
    title_marker = "@agentic_sessions_status_title"
    hint_marker = "@agentic_sessions_status_hint"
    ensure_tmux_status_segment(
        "status-left",
        title_marker,
        "@agentic_sessions_status_original_left",
        "#{@agentic_sessions_status_title}",
        False,
        dry_run,
    )
    ensure_tmux_status_segment(
        "status-right",
        hint_marker,
        "@agentic_sessions_status_original_right",
        "#[default]#{@agentic_sessions_status_hint}",
        True,
        dry_run,
    )
    ensure_tmux_status_length("status-left-length", 32, dry_run)
    ensure_tmux_status_length("status-right-length", 120, dry_run)
    run_tmux(["set-option", "-q", title_marker, tmux_status_title(providers)], dry_run)
    run_tmux(["set-option", "-q", hint_marker, tmux_status_hint(providers)], dry_run)
    run_tmux(["set-option", "-q", "status", "on"], dry_run)


def install_tmux_help_key(providers: Sequence[str], dry_run: bool = False) -> None:
    run_tmux(["bind-key", "?", "run-shell", tmux_help_popup_script(providers)], dry_run)


def tmux_prefix_key_bound(key: str) -> bool:
    try:
        result = subprocess.run(
            ["tmux", "list-keys", "-T", "prefix", key],
            text=True,
            check=False,
            capture_output=True,
        )
    except Exception:
        return True
    return result.returncode == 0 and bool(result.stdout.strip())


def install_sidebar_reopen_key(
    script_path: str,
    python_bin: str,
    provider_text: str,
    codex_bin: str,
    claude_bin: str,
    width: str,
    dry_run: bool = False,
) -> None:
    keys = ("b", "S")
    fallback_cmd = (
        "cmd=\"exec "
        + shell_quote(python_bin)
        + " "
        + shell_quote(script_path)
        + " --provider "
        + shell_quote(provider_text)
        + " sidebar --target-pane '$target' --codex-bin "
        + shell_quote(codex_bin)
        + " --claude-bin "
        + shell_quote(claude_bin)
        + "\"; "
    )
    script = (
        "current=$(tmux display-message -p '##{pane_id}'); "
        "target=$(tmux show-option -wqv @agentic_sessions_target_pane); "
        "cmd=$(tmux show-option -wqv @agentic_sessions_sidebar_cmd); "
        "saved_width=$(tmux show-option -wqv @agentic_sessions_sidebar_width); "
        "sidebar=$(tmux show-option -wqv @agentic_sessions_sidebar_pane); "
        "[ -n \"$target\" ] || target=\"$current\"; "
        "width=\"$saved_width\"; [ -n \"$width\" ] || width="
        + shell_quote(width)
        + "; "
        "if [ -n \"$sidebar\" ] && tmux list-panes -a -F '##{pane_id}' | grep -Fx -- \"$sidebar\" >/dev/null 2>&1; "
        "then tmux select-pane -t \"$sidebar\"; exit 0; fi; "
        "if ! tmux list-panes -a -F '##{pane_id}' | grep -Fx -- \"$target\" >/dev/null 2>&1; "
        "then target=\"$current\"; cmd=; fi; "
        "if [ -z \"$cmd\" ]; then "
        + fallback_cmd
        + "fi; "
        "new=$(tmux split-window -h -b -l \"$width\" -t \"$target\" -P -F '##{pane_id}' \"$cmd\"); "
        "tmux set-option -wq @agentic_sessions_target_pane \"$target\"; "
        "tmux set-option -wq @agentic_sessions_sidebar_width \"$width\"; "
        "tmux set-option -wq @agentic_sessions_sidebar_cmd \"$cmd\"; "
        "tmux set-option -wq @agentic_sessions_sidebar_pane \"$new\"; "
        "tmux select-pane -t \"$target\""
    )
    for key in keys:
        run_tmux(["bind-key", key, "run-shell", script], dry_run)


def tmux_prefix_key(default: str = "prefix") -> str:
    try:
        result = subprocess.run(
            ["tmux", "show-option", "-gqv", "prefix"],
            text=True,
            check=False,
            capture_output=True,
        )
    except Exception:
        return default
    prefix = result.stdout.strip()
    return prefix or default


def right_pane_help_command(providers: Sequence[str]) -> str:
    title = providers_title(providers)
    return """prefix="$(tmux show-option -gqv prefix 2>/dev/null || true)"
[ -n "$prefix" ] || prefix="prefix"
cat <<AGENTIC_SESSIONS_HELP
""" + title + """ Sessions tmux workspace

Sidebar keys:
  j/k or arrows : move
  Enter         : resume here
  r             : native rename active session
  d             : trash; confirm DELETE
  /             : search
  c             : clear search
  q             : close sidebar

Tmux pane keys:
  ${prefix} + Left : focus sidebar pane
  ${prefix} + Right: focus agent pane
  ${prefix} + ?    : show key help popup
  ${prefix} + b    : reopen sidebar if closed
  mouse click     : focus clicked pane if tmux mouse is on

The tmux status bar keeps the workspace title and pane keys visible
across both panes, even after the sidebar closes.
Select a session from the left pane to start.
AGENTIC_SESSIONS_HELP
exec "${SHELL:-/bin/bash}" -l"""


def print_right_pane_help(providers: Sequence[str]) -> None:
    prefix = tmux_prefix_key()
    print(
        f"{providers_title(providers)} Sessions tmux workspace\n\n"
        "Sidebar keys:\n"
        "  j/k or arrows : move\n"
        "  Enter         : resume here\n"
        "  r             : native rename active session\n"
        "  d             : trash; confirm DELETE\n"
        "  /             : search\n"
        "  c             : clear search\n"
        "  q             : close sidebar\n\n"
        "Tmux pane keys:\n"
        f"  {prefix} + Left : focus sidebar pane\n"
        f"  {prefix} + Right: focus agent pane\n"
        f"  {prefix} + ?    : show key help popup\n"
        f"  {prefix} + b    : reopen sidebar if closed\n"
        "  mouse click  : focus clicked pane if tmux mouse is on\n\n"
        "The tmux status bar keeps the workspace title and pane keys visible\n"
        "across both panes, even after the sidebar closes.\n"
        "Select a session from the left pane to start.\n",
        flush=True,
    )


def sidebar_shell_command(
    script: str,
    right_pane: str,
    codex_bin: str,
    claude_bin: str,
    python_bin: str,
    provider_text: str,
    config: Config | None,
) -> str:
    command = (
        "log=/tmp/agentic-sessions-sidebar-${TMUX_PANE#%}.log; "
        "while [ \"$(tmux display-message -p -t "
        + shell_quote(right_pane)
        + " '#{session_attached}' 2>/dev/null)\" = \"0\" ]; do sleep 0.1; done; exec "
        + shell_quote(python_bin)
        + " "
        + shell_quote(script)
        + " --provider "
        + shell_quote(provider_text)
    )
    if config is not None:
        command += (
            " --agent-home "
            + shell_quote(str(config.agent_home))
            + " --sessions-root "
            + shell_quote(str(config.sessions_root))
            + " --state-root "
            + shell_quote(str(config.state_root))
        )
    return (
        command
        + " sidebar --target-pane "
        + shell_quote(right_pane)
        + " --codex-bin "
        + shell_quote(codex_bin)
        + " --claude-bin "
        + shell_quote(claude_bin)
        + " 2>>\"$log\""
    )


def command_tmux(args: argparse.Namespace) -> int:
    ensure_tmux()
    providers = selected_providers(args)
    provider_text = ",".join(providers)
    frozen_config = build_config(args, providers[0]) if len(providers) == 1 else None
    script = str(Path(__file__).resolve())
    python_bin = sys.executable or "python3"
    session_name = args.name
    width = str(args.width)
    placeholder = right_pane_help_command(providers)

    if args.dry_run:
        print("# tmux commands that would be used")

    if os.environ.get("TMUX") and not args.new_session:
        if not args.dry_run:
            print_right_pane_help(providers)
        right_pane = subprocess.run(
            ["tmux", "display-message", "-p", "#{pane_id}"],
            text=True,
            check=True,
            capture_output=True,
        ).stdout.strip()
        sidebar_cmd = sidebar_shell_command(
            script, right_pane, args.codex_bin, args.claude_bin, python_bin, provider_text, frozen_config
        )
        if args.dry_run:
            print(f"# inside tmux: split current window; target right pane is {right_pane}")
            split_sidebar_pane(right_pane, width, sidebar_cmd, True)
            remember_sidebar_reopen(right_pane, "", sidebar_cmd, width, True)
            install_sidebar_reopen_key(script, python_bin, provider_text, args.codex_bin, args.claude_bin, width, True)
            install_tmux_help_key(providers, True)
            install_tmux_status_hint(providers, True)
            run_tmux(["select-pane", "-t", right_pane], True)
            return 0
        sidebar_pane = split_sidebar_pane(right_pane, width, sidebar_cmd)
        remember_sidebar_reopen(right_pane, sidebar_pane, sidebar_cmd, width)
        install_sidebar_reopen_key(script, python_bin, provider_text, args.codex_bin, args.claude_bin, width)
        install_tmux_help_key(providers)
        install_tmux_status_hint(providers)
        run_tmux(["select-pane", "-t", right_pane])
        return 0

    run_tmux(["new-session", "-d", "-s", session_name, "-n", provider_text, placeholder], args.dry_run)
    if args.dry_run:
        print("# plus: capture right pane id, split left, attach")
        return 0
    right_pane = subprocess.run(
        ["tmux", "display-message", "-p", "-t", f"{session_name}:0.0", "#{pane_id}"],
        text=True,
        check=True,
        capture_output=True,
    ).stdout.strip()
    sidebar_cmd = sidebar_shell_command(
        script, right_pane, args.codex_bin, args.claude_bin, python_bin, provider_text, frozen_config
    )
    sidebar_pane = split_sidebar_pane(right_pane, width, sidebar_cmd)
    remember_sidebar_reopen(right_pane, sidebar_pane, sidebar_cmd, width)
    install_sidebar_reopen_key(script, python_bin, provider_text, args.codex_bin, args.claude_bin, width)
    install_tmux_help_key(providers)
    install_tmux_status_hint(providers)
    run_tmux(["select-pane", "-t", right_pane])
    if args.no_attach:
        print(f"created tmux session: {session_name}")
        print(f"attach with: tmux attach -t {session_name}")
        return 0
    os.execvp("tmux", ["tmux", "attach", "-t", session_name])
    return 127


def sidebar_line(session: Session, width: int, selected: bool) -> str:
    marker = "›" if selected else " "
    custom = "★ " if session.custom_title else ""
    age = format_time(session.modified)[5:16]
    cwd_text = short_cwd(session.cwd, 18)
    prefix = f"{marker} {provider_label(session.provider):<2} {age} {cwd_text:<18} "
    if width >= 34:
        title_width = max(8, width - len(prefix))
        return f"{prefix}{custom}{shorten(session.title, max(1, title_width - len(custom)))}"
    title_width = max(8, width - 17)
    return f"{marker} {age} {custom}{shorten(session.title, title_width)}"


def sidebar_card_height(width: int) -> int:
    return 6 if width >= 34 else 1


def sidebar_card_stride(width: int, height: int) -> int:
    card_height = sidebar_card_height(width)
    if card_height == 1:
        return 1
    available = max(0, height - 5)
    return card_height + 1 if available >= (card_height * 2) + 1 else card_height


def fit_cell(text: str, width: int) -> str:
    return shorten(text, max(1, width)).ljust(max(0, width))


def box_border(left: str, right: str, label: str, width: int) -> str:
    inner_width = max(0, width - 2)
    label = shorten(label, inner_width)
    return left + label + ("─" * max(0, inner_width - len(label))) + right


def box_content(text: str, width: int) -> str:
    inner_width = max(0, width - 4)
    return "│ " + fit_cell(text, inner_width) + " │"


def prompt_context_lines(session: Session, width: int) -> list[str]:
    text = normalize_ws(session.first_prompt or session.last_prompt or "")
    if not text:
        return ["context: -", "          "]
    inner_width = max(1, width - 4)
    first_prefix = "context: "
    next_prefix = "         "
    chunks = textwrap.wrap(
        text,
        width=max(8, inner_width - len(first_prefix)),
        break_long_words=False,
        drop_whitespace=True,
    )
    first = chunks[0] if chunks else ""
    rest = " ".join(chunks[1:])
    continuation = textwrap.wrap(
        rest,
        width=max(8, inner_width - len(next_prefix)),
        break_long_words=False,
        drop_whitespace=True,
    )
    return [first_prefix + first, next_prefix + (continuation[0] if continuation else "")]


def sidebar_card_lines(session: Session, width: int, selected: bool) -> list[str]:
    if sidebar_card_height(width) == 1:
        return [sidebar_line(session, width, selected)]
    marker = "›" if selected else " "
    age = format_time(session.modified)[5:16]
    if session.custom_title:
        name = "name: ★ " + session.custom_title
    elif session.native_title:
        name = "name: " + session.native_title
    else:
        name = "name: -"
    context = prompt_context_lines(session, width)
    cwd_text = short_cwd(session.cwd, max(10, width - 10))
    provider = sidebar_provider_label(session.provider, width)
    return [
        box_border("╭", "╮", f"─ {marker} {provider} {age} ", width),
        box_content("cwd: " + cwd_text, width),
        box_content(name, width),
        box_content(context[0], width),
        box_content(context[1], width),
        box_border("╰", "╯", f"─ {session.id[:12]} ", width),
    ]


def safe_color_pair(pair_number: int, fallback: int = curses.A_NORMAL) -> int:
    try:
        return curses.color_pair(pair_number)
    except curses.error:
        return fallback


def sidebar_attrs() -> dict:
    attrs = {
        "header": curses.A_REVERSE,
        "help": curses.A_DIM,
        "row": curses.A_NORMAL,
        "selected": curses.A_REVERSE | curses.A_BOLD,
        "footer": curses.A_DIM,
        "message": curses.A_REVERSE,
    }
    if not curses.has_colors():
        return attrs
    try:
        curses.start_color()
        try:
            curses.use_default_colors()
            default_bg = -1
        except curses.error:
            default_bg = curses.COLOR_BLACK
        if curses.COLORS >= 256:
            accent = 173
            accent_soft = 180
            muted = 245
            selected_fg = 235
            curses.init_pair(1, accent, default_bg)
            curses.init_pair(2, selected_fg, accent_soft)
            curses.init_pair(3, muted, default_bg)
            curses.init_pair(4, accent_soft, default_bg)
        else:
            curses.init_pair(1, curses.COLOR_YELLOW, default_bg)
            curses.init_pair(2, curses.COLOR_WHITE, default_bg)
            curses.init_pair(3, curses.COLOR_WHITE, default_bg)
            curses.init_pair(4, curses.COLOR_YELLOW, default_bg)
    except curses.error:
        return attrs
    attrs.update(
        {
            "header": safe_color_pair(1, curses.A_REVERSE) | curses.A_BOLD,
            "help": safe_color_pair(3, curses.A_DIM) | curses.A_DIM,
            "selected": safe_color_pair(2, curses.A_REVERSE) | curses.A_REVERSE | curses.A_BOLD,
            "footer": safe_color_pair(3, curses.A_DIM) | curses.A_DIM,
            "message": safe_color_pair(4, curses.A_REVERSE) | curses.A_BOLD,
        }
    )
    return attrs


def prompt(stdscr: curses.window, row: int, label: str, initial: str = "") -> str | None:
    curses.echo()
    curses.curs_set(1)
    height, width = stdscr.getmaxyx()
    stdscr.move(row, 0)
    stdscr.clrtoeol()
    text = f"{label}: "
    stdscr.addnstr(row, 0, text, width - 1)
    if initial:
        stdscr.addnstr(initial, max(0, width - len(text) - 1))
    stdscr.refresh()
    try:
        value = stdscr.getstr(row, len(text), max(1, width - len(text) - 1)).decode()
    except KeyboardInterrupt:
        value = None
    curses.noecho()
    curses.curs_set(0)
    return value


def prepare_pane_for_resume(target_pane: str, suspend_running: bool) -> None:
    if not suspend_running:
        return
    subprocess.run(["tmux", "send-keys", "-t", target_pane, "C-z"], check=False)
    time.sleep(0.35)


def send_resume_to_pane(target_pane: str, session: Session, agent_bin: str, kill_running: bool) -> None:
    prepare_pane_for_resume(target_pane, kill_running)
    subprocess.run(
        ["tmux", "send-keys", "-t", target_pane, resume_shell_command(session, agent_bin), "Enter"],
        check=False,
    )
    subprocess.run(["tmux", "select-pane", "-t", target_pane], check=False)


def active_session_key(session: Session) -> str:
    return session_name_key(session.provider, session.id)


def sanitize_native_name(name: str) -> str:
    return normalize_ws("".join(char for char in name if char.isprintable()), limit=120)


def default_native_rename_title(session: Session) -> str:
    title = session.native_title or session.custom_title
    return sanitize_native_name(title)


def capture_pane_tail(target_pane: str, lines: int = 40) -> str:
    try:
        result = subprocess.run(
            ["tmux", "capture-pane", "-p", "-J", "-t", target_pane, "-S", f"-{lines}"],
            text=True,
            check=False,
            capture_output=True,
        )
    except Exception:
        return ""
    return result.stdout if result.returncode == 0 else ""


def pane_current_command(target_pane: str) -> str:
    try:
        result = subprocess.run(
            ["tmux", "display-message", "-p", "-t", target_pane, "#{pane_current_command}"],
            text=True,
            check=False,
            capture_output=True,
        )
    except Exception:
        return ""
    return result.stdout.strip() if result.returncode == 0 else ""


def pane_command_matches_provider(target_pane: str, session: Session, agent_bin: str) -> bool:
    current = Path(pane_current_command(target_pane)).name.lower()
    configured = Path(agent_bin).name.lower()
    if not current:
        return False
    if configured and current == configured:
        return True
    if session.provider == "claude":
        return current == "claude"
    return current in {"codex", "qgenie"}


def pane_looks_ready_for_slash_command(target_pane: str, session: Session, agent_bin: str) -> bool:
    if not pane_command_matches_provider(target_pane, session, agent_bin):
        return False
    tail = [line.rstrip() for line in capture_pane_tail(target_pane, lines=30).splitlines()]
    visible = [line for line in tail if line.strip()]
    prompt_markers = ("❯", "›")
    for line in visible[-8:]:
        stripped = line.strip()
        if stripped in {"❯", ">", "›"}:
            return True
        if stripped.startswith(prompt_markers):
            return True
    return False


def send_native_rename_to_pane(target_pane: str, title: str, submit: bool = True) -> None:
    subprocess.run(["tmux", "send-keys", "-t", target_pane, "C-u"], check=False)
    subprocess.run(["tmux", "send-keys", "-t", target_pane, "-l", "/rename"], check=False)
    subprocess.run(["tmux", "send-keys", "-t", target_pane, "Space"], check=False)
    if title:
        subprocess.run(["tmux", "send-keys", "-t", target_pane, "-l", title], check=False)
    if submit:
        subprocess.run(["tmux", "send-keys", "-t", target_pane, "Enter"], check=False)
    subprocess.run(["tmux", "select-pane", "-t", target_pane], check=False)


def sidebar_curses(stdscr: curses.window, args: argparse.Namespace) -> int:
    configs = build_configs(args)
    providers = [config.provider for config in configs]
    agent_bins = {provider: agent_bin_for(args, provider) for provider in providers}
    curses.curs_set(0)
    attrs = sidebar_attrs()
    stdscr.timeout(120)
    selected = 0
    query = ""
    tmux_prefix = tmux_prefix_key()
    help_text = "↑↓/j/k move · Enter resume · / search · ? details · q close"
    help_lines = [help_text]
    message = help_text
    active_key = ""
    show_help = False
    sessions: list[Session] = []
    names_by_provider: dict[str, dict] = {}
    enriched_paths: set[str] = set()
    loader: SidebarIndexLoader | None = None
    needs_reload = True
    while True:
        if needs_reload:
            loader = SidebarIndexLoader(configs, query, include_generated=include_generated_sessions(args))
            sessions = loader.load_more(0, limit=args.limit, path_budget=250)
            names_by_provider = loader.names_by_provider
            enriched_paths = set()
            needs_reload = False
            message = loader.status(len(sessions)) if sessions or not loader.done else "no sessions found"
            selected = min(selected, len(sessions) - 1) if sessions else 0
        elif loader and not loader.done:
            added = loader.load_more(len(sessions), limit=args.limit, path_budget=80)
            if added:
                selected_key = (
                    session_name_key(sessions[selected].provider, sessions[selected].id) if sessions else ""
                )
                sessions.extend(added)
                sessions.sort(key=lambda session: session.modified, reverse=True)
                if selected_key:
                    selected = next(
                        (
                            idx
                            for idx, session in enumerate(sessions)
                            if session_name_key(session.provider, session.id) == selected_key
                        ),
                        min(selected, len(sessions) - 1),
                    )
                else:
                    selected = 0
            message = loader.status(len(sessions))
            if loader.done and not sessions:
                message = "no sessions found"
        height, width = stdscr.getmaxyx()
        draw_width = max(1, width - 1)
        stdscr.erase()
        header = f" {providers_title(providers)} Sessions " + (f"/{query}" if query else "")
        stdscr.addnstr(0, 0, header.ljust(draw_width), draw_width, attrs["header"])
        if show_help:
            help_lines = [
                "Keys  ↑↓/j/k move · PgUp/PgDn jump · Enter resume selected",
                "Edit  r native rename active · d trash · / search · c clear · R refresh",
                f"Tmux  {tmux_prefix}+b sidebar · {tmux_prefix}+←/→ panes · mouse click focus",
                "Help  ? hide keys · q close sidebar",
            ]
        else:
            help_lines = [help_text]
        list_start = 1 + len(help_lines)
        card_height = sidebar_card_height(draw_width)
        card_stride = sidebar_card_stride(draw_width, height)
        max_cards = max(0, (height - list_start - 2) // card_stride)
        page_size = max(1, max_cards)
        start = max(0, selected - page_size + 1)
        visible = sessions[start : start + page_size]
        for line_offset, help_line in enumerate(help_lines):
            stdscr.addnstr(1 + line_offset, 0, shorten(help_line, draw_width).ljust(draw_width), draw_width, attrs["help"])
        for offset, session in enumerate(visible):
            absolute_index = start + offset
            path_key = str(session.path)
            if path_key not in enriched_paths:
                config = config_for_provider(configs, session.provider)
                parsed = parse_session(
                    session.path,
                    names_by_provider.get(session.provider, {}),
                    session.provider,
                    fast_sidebar=True,
                )
                if parsed:
                    session = parsed
                    sessions[absolute_index] = parsed
                enriched_paths.add(path_key)
            row = list_start + offset * card_stride
            is_selected = absolute_index == selected
            attr = attrs["selected"] if is_selected else attrs["row"]
            for line_offset, line in enumerate(sidebar_card_lines(session, draw_width, is_selected)):
                stdscr.addnstr(row + line_offset, 0, line.ljust(draw_width), draw_width, attr)
        footer_row = height - 2
        if sessions:
            current = sessions[selected]
            detail = (
                f"{selected + 1}/{len(sessions)} {current.provider}:{current.id[:12]} "
                f"{short_cwd(current.cwd, max(10, width - 34))}"
            )
        else:
            detail = "no sessions"
        stdscr.addnstr(footer_row, 0, detail.ljust(draw_width), draw_width, attrs["footer"])
        stdscr.addnstr(height - 1, 0, shorten(message, draw_width).ljust(draw_width), draw_width, attrs["message"])
        stdscr.refresh()
        key = stdscr.getch()
        if key == -1:
            continue
        if key in (ord("q"), 27):
            return 0
        if key == ord("?"):
            show_tmux_help_popup(providers)
            show_help = not show_help
            message = "showing key help" if show_help else help_text
            continue
        if key in (curses.KEY_DOWN, ord("j")):
            selected = min(selected + 1, max(0, len(sessions) - 1))
        elif key in (curses.KEY_UP, ord("k")):
            selected = max(0, selected - 1)
        elif key in (curses.KEY_NPAGE, ord(" ")):
            selected = min(selected + page_size, max(0, len(sessions) - 1))
        elif key == curses.KEY_PPAGE:
            selected = max(0, selected - page_size)
        elif key in (ord("/"),):
            value = prompt(stdscr, height - 1, "search", query)
            if value is not None:
                query = value.strip()
                selected = 0
                needs_reload = True
        elif key in (ord("c"),):
            query = ""
            selected = 0
            needs_reload = True
        elif key == ord("R"):
            needs_reload = True
        elif key in (10, 13):
            if sessions:
                current = sessions[selected]
                send_resume_to_pane(args.target_pane, current, agent_bins[current.provider], args.kill_running)
                active_key = active_session_key(current)
                message = f"sent resume for {sessions[selected].id[:12]}"
        elif key == ord("r"):
            if sessions:
                current = sessions[selected]
                if active_session_key(current) != active_key:
                    message = "resume this session first to native rename"
                elif not pane_looks_ready_for_slash_command(args.target_pane, current, agent_bins[current.provider]):
                    message = "wait, session busy"
                else:
                    default_title = default_native_rename_title(current)
                    send_native_rename_to_pane(args.target_pane, default_title, submit=False)
                    message = "edit native name in agent pane"
        elif key == ord("d"):
            if sessions:
                current = sessions[selected]
                value = prompt(stdscr, height - 1, "type DELETE to trash", "")
                if value == "DELETE":
                    config = config_for_provider(configs, current.provider)
                    move_to_trash(config, current)
                    message = f"trashed {current.id[:12]}"
                    selected = max(0, selected - 1)
                    needs_reload = True
                else:
                    message = "delete cancelled"


def command_sidebar(args: argparse.Namespace) -> int:
    if args.render_once:
        configs = build_configs(args)
        print_sessions(
            load_session_index_from_configs(configs, limit=args.limit, include_generated=include_generated_sessions(args))
        )
        return 0
    if not args.target_pane:
        raise SystemExit("sidebar requires --target-pane")
    return curses.wrapper(sidebar_curses, args)


def add_global_args(parser: argparse.ArgumentParser) -> None:
    parser.add_argument(
        "--provider",
        default=argparse.SUPPRESS,
        help="comma-separated session providers: codex, claude, or codex,claude; default: both",
    )
    parser.add_argument(
        "--agent-home",
        default=argparse.SUPPRESS,
        help="agent home/config dir; default from CODEX_HOME/CLAUDE_CONFIG_DIR or ~/.codex/~/.claude",
    )
    parser.add_argument(
        "--sessions-root",
        default=argparse.SUPPRESS,
        help="session root; default: provider env or <agent-home>/sessions|projects",
    )
    parser.add_argument(
        "--state-root",
        default=argparse.SUPPRESS,
        help="sidecar metadata root; default: <agent-home>/session-tools",
    )


def build_parser() -> argparse.ArgumentParser:
    program_name = Path(sys.argv[0]).name or "agentic-sessions"
    parser = argparse.ArgumentParser(
        prog=program_name,
        description="List, rename, trash, resume, and tmux-browse Codex or Claude Code sessions.",
    )
    add_global_args(parser)
    sub = parser.add_subparsers(dest="command", required=True)

    p = sub.add_parser("paths", help="show resolved paths")
    add_global_args(p)
    p.set_defaults(func=command_paths)

    p = sub.add_parser("doctor", help="check local runtime dependencies")
    add_global_args(p)
    p.add_argument("--strict", action="store_true", help="fail if optional agent/tmux dependencies are missing")
    p.set_defaults(func=command_doctor)

    p = sub.add_parser("list", help="list sessions")
    add_global_args(p)
    p.add_argument("-q", "--query", help="case-insensitive filter")
    p.add_argument("-n", "--limit", type=int, default=50, help="maximum rows; use 0 for all")
    p.add_argument("--long", action="store_true", help="include cwd and file path")
    p.add_argument("--json", action="store_true", help="emit JSON")
    p.add_argument("--scan-all-prompts", action="store_true", help="slower: scan full rollouts for last prompt")
    p.add_argument("--all", action="store_true", help="include generated/background child sessions")
    p.set_defaults(func=command_list)

    p = sub.add_parser("rename", help="set or clear a custom session title")
    add_global_args(p)
    p.add_argument("selector", help="session id/prefix/title fragment")
    p.add_argument("title", help="new title; pass empty string to clear")
    p.add_argument("--match-limit", type=int, default=200, help="maximum matching rows to scan")
    p.add_argument("--all", action="store_true", help="include generated/background child sessions")
    p.set_defaults(func=command_rename)

    p = sub.add_parser("delete", aliases=["trash"], help="move a session file to sidecar trash")
    add_global_args(p)
    p.add_argument("selector", help="session id/prefix/title fragment")
    p.add_argument("-y", "--yes", action="store_true", help="do not prompt")
    p.add_argument("--match-limit", type=int, default=200, help="maximum matching rows to scan")
    p.add_argument("--all", action="store_true", help="include generated/background child sessions")
    p.set_defaults(func=command_delete)

    p = sub.add_parser("resume", help="exec provider resume for a selected session")
    add_global_args(p)
    p.add_argument("selector", help="session id/prefix/title fragment")
    p.add_argument("--codex-bin", default=default_codex_bin(), help="codex executable")
    p.add_argument("--claude-bin", default=default_claude_bin(), help="claude executable")
    p.add_argument("--print-command", action="store_true", help="print instead of exec")
    p.add_argument("--match-limit", type=int, default=200, help="maximum matching rows to scan")
    p.add_argument("--all", action="store_true", help="include generated/background child sessions")
    p.set_defaults(func=command_resume)

    p = sub.add_parser("tmux", help="launch a tmux workspace with a sessions sidebar")
    add_global_args(p)
    p.add_argument("--name", default=program_name, help="tmux session name")
    p.add_argument("--width", type=int, default=56, help="sidebar width in columns")
    p.add_argument("--no-attach", action="store_true", help="create detached and print attach command")
    p.add_argument("--new-session", action="store_true", help="force a new tmux session even inside tmux")
    p.add_argument("--dry-run", action="store_true", help="print tmux commands only")
    p.add_argument("--codex-bin", default=default_codex_bin(), help="codex executable")
    p.add_argument("--claude-bin", default=default_claude_bin(), help="claude executable")
    p.set_defaults(func=command_tmux)

    p = sub.add_parser("sidebar", help=argparse.SUPPRESS)
    add_global_args(p)
    p.add_argument("--target-pane", help="tmux pane id to receive codex resume commands")
    p.add_argument("--codex-bin", default=default_codex_bin(), help="codex executable")
    p.add_argument("--claude-bin", default=default_claude_bin(), help="claude executable")
    suspend_group = p.add_mutually_exclusive_group()
    suspend_group.add_argument(
        "--suspend-running",
        "--kill-running",
        dest="kill_running",
        action="store_true",
        default=True,
        help="suspend the right-pane process with Ctrl-Z before sending resume",
    )
    suspend_group.add_argument(
        "--no-suspend-running",
        "--no-kill-running",
        dest="kill_running",
        action="store_false",
        help="send resume without first suspending the right-pane process",
    )
    p.add_argument("--render-once", action="store_true")
    p.add_argument("--limit", type=int, default=0)
    p.add_argument("--all", action="store_true", help="include generated/background child sessions")
    p.set_defaults(func=command_sidebar)

    return parser


def main(argv: Sequence[str] | None = None) -> int:
    load_local_env()
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
